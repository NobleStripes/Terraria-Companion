{
  "name": "terraria-companion",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "author": "NobleStripes",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "validate:data": "node scripts/validate-items.mjs && node scripts/validate-build-recommendations.mjs",
    "clean": "rimraf dist",
    "build": "npm run validate:data && npm run clean && tsc -b && vite build",
    "test": "node --experimental-strip-types --test tests/*.test.mjs tests/*.test.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "lib:build": "tsc -b --declaration --declarationMap --emitDeclarationOnly --outDir dist",
    "lib:prepublishonly": "npm run lib:build"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
