{
  "name": "terraria-companion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "author": "NobleStripes",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "clean": "powershell -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "build": "npm run clean && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npm run clean && npm run build && electron-builder",
    "electron-build:win": "npm run clean && npm run build && electron-builder --win",
    "electron-build:mac": "npm run clean && npm run build && electron-builder --mac",
    "electron-build:linux": "npm run clean && npm run build && electron-builder --linux",
    "lib:build": "tsc -b --declaration --declarationMap --emitDeclarationOnly --outDir dist",
    "lib:prepublishonly": "npm run lib:build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
